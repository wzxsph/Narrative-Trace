{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narrative-trace.dev/schemas/kernel/v1/pack.schema.json",
  "title": "Narrative Trace Content Pack Manifest V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "title",
    "version",
    "kernel_version",
    "loop_package",
    "surfaces_used",
    "runtime_compat",
    "authorship",
    "experimental_notice",
    "entrypoints",
    "extensions"
  ],
  "properties": {
    "schema_version": {"const": "narrative_content_pack_v1"},
    "pack_id": {"$ref": "common.schema.json#/$defs/id"},
    "title": {"type": "string", "minLength": 1},
    "version": {"$ref": "common.schema.json#/$defs/version"},
    "kernel_version": {"const": "1.0.0"},
    "loop_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "tier", "verification_status"],
      "properties": {
        "id": {"$ref": "common.schema.json#/$defs/id"},
        "version": {"$ref": "common.schema.json#/$defs/version"},
        "tier": {"enum": ["verified", "experimental"]},
        "verification_status": {"enum": ["verified", "debt", "experimental"]}
      },
      "allOf": [
        {
          "if": {"properties": {"tier": {"const": "verified"}}, "required": ["tier"]},
          "then": {"properties": {"verification_status": {"enum": ["verified", "debt"]}}}
        },
        {
          "if": {"properties": {"tier": {"const": "experimental"}}, "required": ["tier"]},
          "then": {"properties": {"verification_status": {"const": "experimental"}}}
        }
      ]
    },
    "surfaces_used": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["text", "image", "html"]}
    },
    "runtime_compat": {
      "type": "string",
      "pattern": "^\\^1\\.[0-9]+\\.[0-9]+$"
    },
    "authorship": {"enum": ["human", "agent_assisted", "agent_generated"]},
    "experimental_notice": {"type": "boolean"},
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["game", "state_registry", "provenance"],
      "properties": {
        "game": {"$ref": "common.schema.json#/$defs/relative_path"},
        "state_registry": {"$ref": "common.schema.json#/$defs/relative_path"},
        "provenance": {"$ref": "common.schema.json#/$defs/relative_path"}
      }
    },
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "loop_package": {
            "properties": {"tier": {"const": "experimental"}},
            "required": ["tier"]
          }
        }
      },
      "then": {"properties": {"experimental_notice": {"const": true}}}
    },
    {
      "if": {
        "properties": {
          "loop_package": {
            "properties": {"tier": {"const": "verified"}},
            "required": ["tier"]
          }
        }
      },
      "then": {"properties": {"experimental_notice": {"const": false}}}
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narrative-trace.dev/schemas/kernel/v1/gate-result.schema.json",
  "title": "Narrative Trace Gate Result V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "gate_id", "gate_version", "status", "input_digest", "errors", "warnings", "evidence"],
  "properties": {
    "schema_version": {"const": "narrative_gate_result_v1"},
    "gate_id": {"enum": ["G1", "G2", "G3", "G4", "G5", "G6"]},
    "gate_version": {"$ref": "common.schema.json#/$defs/version"},
    "status": {"enum": ["passed", "failed", "pending"]},
    "input_digest": {"$ref": "common.schema.json#/$defs/sha256"},
    "errors": {"type": "array", "items": {"$ref": "#/$defs/message"}},
    "warnings": {"type": "array", "items": {"$ref": "#/$defs/message"}},
    "evidence": {"type": "object"}
  },
  "$defs": {
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "location", "message"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "location": {"type": "string", "minLength": 1},
        "message": {"type": "string", "minLength": 1}
      }
    }
  }
}

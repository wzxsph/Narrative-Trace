{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narrative-trace.dev/schemas/kernel/v1/provenance.schema.json",
  "title": "Narrative Trace Provenance Manifest V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "authorship", "schema_versions", "trace_version", "artifacts"],
  "properties": {
    "schema_version": {"const": "narrative_provenance_v1"},
    "authorship": {"enum": ["human", "agent_assisted", "agent_generated"]},
    "prompt_set": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1},
    "schema_versions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "trace_version": {"type": "string", "minLength": 1},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"$ref": "common.schema.json#/$defs/relative_path"},
          "sha256": {"$ref": "common.schema.json#/$defs/sha256"}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"authorship": {"enum": ["agent_assisted", "agent_generated"]}}},
      "then": {"required": ["prompt_set", "provider", "model"]}
    }
  ]
}

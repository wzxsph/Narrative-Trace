{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narrative-trace.dev/loop-packages/investigation/v1/schema-extension.schema.json",
  "title": "Investigation Loop V1 Game Extension",
  "type": "object",
  "required": ["extensions", "scenes", "endings"],
  "properties": {
    "extensions": {
      "type": "object",
      "required": ["investigation"],
      "properties": {
        "investigation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["chapters", "guidance_policy", "path_review"],
          "properties": {
            "chapters": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "title"],
                "properties": {
                  "id": {"type": "string", "minLength": 1},
                  "title": {"type": "string", "minLength": 1}
                }
              }
            },
            "guidance_policy": {"const": "diegetic_once"},
            "path_review": {"const": true}
          }
        }
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["extensions", "actions"],
        "properties": {
          "extensions": {
            "type": "object",
            "required": ["investigation"],
            "properties": {
              "investigation": {
                "type": "object",
                "additionalProperties": false,
                "required": ["chapter_id", "chapter_title", "title", "task", "pressure", "main_scene"],
                "properties": {
                  "chapter_id": {"type": "string", "minLength": 1},
                  "chapter_title": {"type": "string", "minLength": 1},
                  "title": {"type": "string", "minLength": 1},
                  "task": {"type": "string", "minLength": 1},
                  "pressure": {"type": "string", "minLength": 1},
                  "main_scene": {"type": "boolean"}
                }
              }
            }
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["extensions"],
              "properties": {
                "extensions": {
                  "type": "object",
                  "required": ["investigation"],
                  "properties": {
                    "investigation": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["kind"],
                      "properties": {
                        "kind": {"enum": ["investigate", "reveal", "conceal", "confront", "trust", "betray", "wait"]}
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "endings": {"type": "array", "minItems": 3}
  }
}

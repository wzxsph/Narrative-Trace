{
  "schema_version": "state_schema_design_v0_1",
  "project_id": "missing_phone",
  "source_plan_schema_version": "generation_plan_v0_1",
  "axes": [
    {
      "id": "clues",
      "purpose": "玩家已经确认的证据和可行动信息。"
    },
    {
      "id": "stance",
      "purpose": "玩家在道德问题上的倾向，而不是显式阵营。"
    },
    {
      "id": "relationships",
      "purpose": "隐藏关系向量，避免单一好感度条。"
    },
    {
      "id": "pressure",
      "purpose": "外部风险与时间压力。"
    }
  ],
  "variables": [
    {
      "key": "clues.unsent_warning",
      "axis": "clues",
      "type": "boolean",
      "initial": false,
      "purpose": "玩家是否理解短信在警告陈。",
      "written_by": [
        "obs_unsent_sms"
      ],
      "read_by": [
        "chapter_review",
        "ending_profile"
      ]
    },
    {
      "key": "clues.station_location",

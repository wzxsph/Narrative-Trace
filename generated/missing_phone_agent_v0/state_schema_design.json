  "relationship_axes": {
    "chen": [
      "trust",
      "suspicion"
    ],
    "lin": [
      "bond"
    ]
  },
  "ending_tags": [
    "ending_publish",
    "ending_bury",
    "ending_confront"
  ],
  "design_rules": [
    "隐藏关系变量必须通过文本回声表现，不能裸露数值。",
    "关键 choice 的 requirements 必须能被 observe 或前置 choice 明确写入。",
    "重大关系变化必须有文本暗示。",
    "pressure 只能改变风险语境，不能黑箱改写玩家意图。"
  ]
}
